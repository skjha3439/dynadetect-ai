# ────────────────────────────────────────────────────────
# DynaDetect AI — Environment Variables
# IIIT Manipur Hackathon — Akumen AI Problem #2
# ────────────────────────────────────────────────────────
# WARNING: Never push this file to GitHub!
# ────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────
HOST=127.0.0.1
PORT=8000

# ── Layer 1a: YOLOv8 ─────────────────────────────────────
YOLO_MODEL=our_model.pt

# ── Layer 1b: Grounding DINO ──────────────────────────────
MODEL_ID=IDEA-Research/grounding-dino-base

# ── Layer 2: CLIP ────────────────────────────────────────
CLIP_MODEL=ViT-B/32

# ── Layer 3: Anti-Forgetting ─────────────────────────────
EWC_LAMBDA=0.4
REPLAY_BUFFER_SIZE=200

# ── Layer 4: FAISS ───────────────────────────────────────
FAISS_DIMENSION=512

# ── Layer 6: SAM — Segment Anything Model ────────────────
SAM_MODEL=facebook/sam-vit-base

# ── Detection Thresholds ─────────────────────────────────
DETECTION_THRESHOLD=0.50
GDINO_THRESHOLD=0.35

# ── Offline Mode (use cached models) ─────────────────────
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1

# ── HuggingFace Token ────────────────────────────────────
HUGGINGFACE_TOKEN=your_token_here

# ── Training ─────────────────────────────────────────────
TRAIN_EPOCHS=50
TRAIN_BATCH=4
TRAIN_IMG_SIZE=416
DATA_YAML=coco128.yaml
OUTPUT_MODEL=our_model.pt
