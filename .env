# ────────────────────────────────────────────────────────
# DynaDetect AI — Environment Variables
# IIIT Manipur Hackathon — Akumen AI Problem #2
# ────────────────────────────────────────────────────────
# WARNING: Never push this file to GitHub!
# Add .env to your .gitignore file
# ────────────────────────────────────────────────────────

# ── Server Configuration ─────────────────────────────────
HOST=127.0.0.1
PORT=8000

# ── Layer 1a: YOLOv8 Model ───────────────────────────────
# Options: yolov8n.pt (fast) | yolov8m.pt | yolov8l.pt (accurate)
YOLO_MODEL=yolov8l.pt

# ── Layer 1b: Grounding DINO Model ───────────────────────
# This is the zero-shot detector for ANY custom object
MODEL_ID=IDEA-Research/grounding-dino-base

# ── Layer 2: CLIP Backbone ───────────────────────────────
# Options: ViT-B/32 (fast) | ViT-B/16 | ViT-L/14 (accurate)
CLIP_MODEL=ViT-B/32

# ── Layer 3: Anti-Forgetting Settings ────────────────────
EWC_LAMBDA=0.4
REPLAY_BUFFER_SIZE=200

# ── Layer 4: FAISS Vector Store ──────────────────────────
FAISS_DIMENSION=512

# ── Detection Thresholds ─────────────────────────────────
# YOLOv8 confidence threshold (higher = fewer but accurate boxes)
DETECTION_THRESHOLD=0.45

# Grounding DINO threshold (lower = detects more objects)
GDINO_THRESHOLD=0.25

# ── HuggingFace Token ────────────────────────────────────
# Only needed if accessing private models
# Get your token from: https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=your_token_here
